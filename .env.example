# App
LOG_LEVEL=1   # 0=debug, 1=info

# Timezone — disamakan dengan main backend (Asia/Jakarta / WIB). Dipakai untuk:
#   - cron wall-clock (jadwal di bawah dibaca sebagai jam WIB, bukan UTC)
#   - perhitungan "hari ini" pada query no-log & dedup (AT TIME ZONE 'Asia/Jakarta')
APP_TIMEZONE=Asia/Jakarta

# Database — sama dengan main backend (Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cron schedules — DITULIS DALAM JAM WIB (lihat APP_TIMEZONE di atas)
# 12:00 WIB (siang) dan 20:00 WIB (malam)
REMINDER_CRON_NOON=0 12 * * *
REMINDER_CRON_EVENING=0 20 * * *

# For testing: run every minute
# REMINDER_CRON_NOON=* * * * *
# REMINDER_CRON_EVENING=* * * * *

# Trend escalation cron (WIB) — evaluasi tren mingguan, sekali sehari (default 06:00 WIB)
TREND_ESCALATION_CRON=0 6 * * *
# Ambang "sustained": minimal jumlah hari berisiko (waswas/bahaya) dalam 7 hari terakhir
# sebelum eskalasi tren dibuat untuk pasien yang skor terbarunya waswas. Default 3.
TREND_WASWAS_DAYS=3
# Cooldown: jeda (hari) sebelum eskalasi tren ulang untuk pasien yang sama setelah alert
# sebelumnya dibuat/ditutup — cegah re-nag harian. Default 7.
TREND_COOLDOWN_DAYS=7

# For testing: run trend job every minute
# TREND_ESCALATION_CRON=* * * * *
