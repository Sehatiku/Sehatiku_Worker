# App
LOG_LEVEL=1   # 0=debug, 1=info

# Database — sama dengan main backend (Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cron schedules (UTC — WIB = UTC+7)
# 12:00 WIB = 05:00 UTC | 20:00 WIB = 13:00 UTC
REMINDER_CRON_NOON=0 5 * * *
REMINDER_CRON_EVENING=0 13 * * *

# For testing: run every minute
# REMINDER_CRON_NOON=* * * * *
# REMINDER_CRON_EVENING=* * * * *
